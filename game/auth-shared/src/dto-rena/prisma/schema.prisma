generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum UserStatus {
  ONLINE
  OFFLINE
  IN_GAME
}

enum MatchMode {
  RANKED
  UNRANKED
  LOCAL
  AI
}

enum MatchType {
  FFA
  TEAM
}

enum CharacterName {
  ADE
  ZEUS
}

enum AchievementType {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum NotificationType {
  FRIEND_REQ
  FRIEND_ACCEPTED
  GAME_INVITE
  ACHV_UNLOCKED
}

enum EndReason {
  TIMEOUT
  RESIGNATION
  KILLOUT
}

enum Provider {
  LOCAL
  GOOGLE
}

// --- MODELS ---

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  username        String   @unique
  avatarUrl       String  @map("avatar_url")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  twoFactorSecret String?  @map("two_factor_secret")
  is2faEnabled    Boolean  @default(false) @map("is_2fa_enabled")
  tokenVersion    Int      @default(0) @map("token_version")
  status          UserStatus @default(OFFLINE)
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  accounts        Account[]
  stats           UserStats?
  characterStats  CharacterStats[]
  
  matchHistory    MatchParticipant[]
  
  sentFriendships     Friendship[]   @relation("Sender")
  receivedFriendships Friendship[]   @relation("Receiver")
  
  sentInvites         GameInvite[]   @relation("SenderInvite")
  receivedInvites     GameInvite[]   @relation("ReceiverInvite")
  
  achievements    UserAchievement[]
  notifications   Notification[]

  @@map("users")
}

model Account {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  provider     Provider
  passwordHash  String?  @map("password_hash")
  oauthId    String?  @map("provider_id")

  @@unique([userId, provider])
  @@unique([provider, oauthId])
  @@map("accounts")
}

model UserStats {
  id               Int @id @default(autoincrement())
  userId           Int @unique @map("user_id")
  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  eloCurrent       Int @default(500) @map("elo_current")
  eloPeak          Int @default(500) @map("elo_peak")
  
  totalWins             Int @default(0) @map("total_wins")
  totalLosses           Int @default(0) @map("total_losses")
  totalDraws            Int @default(0) @map("total_draws")
  
  currentWinStreak Int @default(0) @map("current_win_streak")
  bestWinStreak    Int @default(0) @map("best_win_streak")
  currentLoseStreak Int @default(0) @map("current_lose_streak")
  
  totalKills       Int @default(0) @map("total_kills")
  totalDeaths      Int @default(0) @map("total_deaths")

  @@index([eloCurrent(sort: Desc)])
  @@map("user_stats")
}

model CharacterStats {
  id             Int           @id @default(autoincrement())
  userId         Int           @map("user_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  characterName  CharacterName @map("character_name")
  
  wins           Int @default(0)
  losses         Int @default(0)
  draws          Int @default(0)
  kills          Int @default(0)
  deaths         Int @default(0)

  @@unique([userId, characterName])
  @@map("character_stats")
}

model Match {
  id              Int       @id @default(autoincrement())
  playedAt        DateTime  @default(now()) @map("played_at")
  mode            MatchMode
  type				MatchType
  durationSeconds	Int       @map("duration_seconds")
  
  endReason		EndReason?	@map("end_reason")
  winningTeamId	Int?		@map("winner_team_id")

  participants    MatchParticipant[]

  @@map("matches")
}

model MatchParticipant {
  id            Int    @id @default(autoincrement())
  
  matchId       Int    @map("match_id")
  match         Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  userId        Int?   @map("user_id")
  user          User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  teamId        Int   @map("team_id")

  characterName CharacterName @map("character_name")
  kills         Int    @default(0)
  deaths        Int    @default(0)

  @@index([matchId])
  @@index([userId])
  @@index([matchId, teamId])
  @@map("match_participants")
}

model Friendship {
  id         Int              @id @default(autoincrement())
  senderId   Int              @map("sender_id")
  receiverId Int              @map("receiver_id")
  sender     User             @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  
  status     FriendshipStatus @default(PENDING) 
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@map("friendships")
}

model GameInvite {
  id         Int          @id @default(autoincrement())
  senderId   Int          @map("sender_id")
  receiverId Int          @map("receiver_id")
  sender     User         @relation("SenderInvite", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User         @relation("ReceiverInvite", fields: [receiverId], references: [id], onDelete: Cascade)
  
  status     InviteStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at")
  expiresAt  DateTime     @map("expires_at")

  @@index([receiverId])
  @@map("game_invites")
}

model Achievement {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String
  iconPath    String  @map("icon_path")
  tier        AchievementType
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int         @id @default(autoincrement())
  userId        Int         @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId Int         @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType 
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("notifications")
}
